{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyAllOutsideUsEast1",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "sts:*",
        "organizations:*",
        "account:*",
        "cloudfront:*",
        "globalaccelerator:*",
        "networkmanager:*",
        "route53:*",
        "route53domains:*",
        "route53-recovery-cluster:*",
        "route53-recovery-control-config:*",
        "route53-recovery-readiness:*",
        "shield:*",
        "waf:*",
        "waf-regional:*",
        "wafv2:*",
        "support:*",
        "trustedadvisor:*",
        "health:*",
        "budgets:*",
        "ce:*",
        "cur:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    }
  ]
}
