# Grant the Elastic Beanstalk EC2 instance profile permission to read/write the
# Cloud Air Bookings table.
#
# The default EB web-tier instance profile (aws-elasticbeanstalk-ec2-role) has
# NO DynamoDB access, so POST /bookings and GET /bookings would fail with
# AccessDenied without this. The policy is scoped to the per-student Bookings-*
# table (and its indexes) and is identical for every userN — no per-student
# editing required. The policy name is suffixed with the environment name so
# each student's EB environment manages its own inline policy on the shared
# default role (clean create and teardown, no collisions).
#
# Full-form intrinsic functions (Fn::Sub / Ref) are used deliberately — the
# .ebextensions YAML parser does not accept the !Sub / !Ref short tags.
Resources:
  CloudAirBookingsAccess:
    Type: AWS::IAM::Policy
    Properties:
      PolicyName:
        Fn::Join: ["-", ["CloudAirBookings", { "Ref": "AWSEBEnvironmentName" }]]
      Roles:
        - aws-elasticbeanstalk-ec2-role
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Action:
              - dynamodb:PutItem
              - dynamodb:GetItem
              - dynamodb:Query
              - dynamodb:Scan
              - dynamodb:UpdateItem
            Resource:
              - Fn::Sub: "arn:aws:dynamodb:${AWS::Region}:${AWS::AccountId}:table/Bookings-*"
              - Fn::Sub: "arn:aws:dynamodb:${AWS::Region}:${AWS::AccountId}:table/Bookings-*/index/*"
